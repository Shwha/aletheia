# Aletheia .gitignore
# Secrets — NEVER commit
.env
*.pem
*.key
credentials.*

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Testing
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# Audit traces — local only, never push
audit/

# OS
.DS_Store
Thumbs.db

# uv
uv.lock

# Aletheia — Environment Configuration
# Copy to .env and fill in your values. NEVER commit .env to version control.
#
# API Keys — at least one required for evaluation
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
# For local models (Ollama, vLLM, llama.cpp)
OLLAMA_API_BASE=http://localhost:11434

# Network Security
# ALETHEIA_PROXY_URL=socks5://127.0.0.1:9050  # TOR/SOCKS5 proxy
# ALETHEIA_TLS_CERT_PATH=                       # Custom CA cert for pinning
# ALETHEIA_VERIFY_TLS=true                      # Set false ONLY for local dev

# Logging
ALETHEIA_LOG_LEVEL=INFO
ALETHEIA_LOG_FORMAT=json

# Report Signing (Phase 2)
# ALETHEIA_SIGNING_KEY_PATH=
